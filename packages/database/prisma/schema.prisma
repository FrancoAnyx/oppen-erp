// =============================================================================
// öppen ERP — Prisma Schema consolidado
// Schemas: core, inventory, sales, purchases, fiscal, accounting
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["core", "inventory", "sales", "purchases", "fiscal", "accounting"]
}

// =============================================================================
// SCHEMA: core
// =============================================================================

model Tenant {
  id           String   @id @default(cuid())
  legalName    String   @map("legal_name")
  cuit         String   @unique
  ivaCondition String   @map("iva_condition")
  posNumber    Int      @default(1) @map("pos_number")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users          User[]
  entities       Entity[]
  categories     ProductCategory[]
  products       Product[]
  locations      Location[]
  stockMoves     StockMove[]
  serials        SerialNumber[]
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]
  posNumbers     PosNumber[]
  receipts       Receipt[]
  bankAccounts   BankAccount[]

  @@map("tenants")
  @@schema("core")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  email        String
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  role         UserRole  @default(USER)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdStockMoves     StockMove[]     @relation("StockMoveCreatedBy")
  createdSalesOrders    SalesOrder[]    @relation("SalesOrderCreatedBy")
  createdPurchaseOrders PurchaseOrder[] @relation("POCreatedBy")
  createdInvoices       Invoice[]       @relation("InvoiceCreatedBy")
  createdReceipts       Receipt[]       @relation("ReceiptCreatedBy")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
  @@schema("core")
}

enum UserRole {
  ADMIN
  MANAGER
  USER
  VIEWER

  @@schema("core")
}

model Entity {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  entityType      String[]  @map("entity_type")
  legalName       String    @map("legal_name")
  tradeName       String?   @map("trade_name")
  taxId           String    @map("tax_id")
  ivaCondition    String    @map("iva_condition")
  email           String?
  phone           String?
  address         String?
  city            String?
  province        String?
  zipCode         String?   @map("zip_code")
  padronData      Json?     @map("padron_data")
  padronSyncedAt  DateTime? @map("padron_synced_at")
  creditLimit     Decimal   @default(0) @map("credit_limit") @db.Decimal(18, 2)
  paymentTermDays Int       @default(0) @map("payment_term_days")
  notes           String?
  isActive        Boolean   @default(true) @map("is_active")
  version         Int       @default(1)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  salesOrders    SalesOrder[]
  supplierOrders PurchaseOrder[] @relation("SupplierOrders")
  receipts       Receipt[]

  @@unique([tenantId, taxId])
  @@index([tenantId, isActive])
  @@index([tenantId, legalName])
  @@map("entities")
  @@schema("core")
}

// =============================================================================
// SCHEMA: inventory
// =============================================================================

model ProductCategory {
  id             String     @id @default(cuid())
  tenantId       String     @map("tenant_id")
  name           String
  parentId       String?    @map("parent_id")
  requiresSerial Boolean    @default(false) @map("requires_serial")
  costMethod     CostMethod @default(AVG) @map("cost_method")
  createdAt      DateTime   @default(now()) @map("created_at")

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  parent   ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryTree")
  products Product[]

  @@unique([tenantId, name])
  @@map("product_categories")
  @@schema("inventory")
}

model Product {
  id           String       @id @default(cuid())
  tenantId     String       @map("tenant_id")
  categoryId   String?      @map("category_id")
  sku          String
  barcode      String?
  name         String
  description  String?
  trackingType TrackingType @default(NONE) @map("tracking_type")
  costMethod   CostMethod   @default(AVG) @map("cost_method")
  listPriceArs Decimal      @map("list_price_ars") @db.Decimal(18, 2)
  weightKg     Decimal?     @map("weight_kg") @db.Decimal(10, 3)
  uom          String       @default("UN")
  isActive     Boolean      @default(true) @map("is_active")
  version      Int          @default(1)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  category           ProductCategory?   @relation(fields: [categoryId], references: [id])
  stockMoves         StockMove[]
  serials            SerialNumber[]
  salesOrderLines    SalesOrderLine[]
  purchaseOrderLines PurchaseOrderLine[]

  @@unique([tenantId, sku])
  @@index([tenantId, isActive])
  @@map("products")
  @@schema("inventory")
}

enum TrackingType {
  NONE
  LOT
  SERIAL

  @@schema("inventory")
}

enum CostMethod {
  FIFO
  AVG
  STD

  @@schema("inventory")
}

model Location {
  id           String       @id @default(cuid())
  tenantId     String       @map("tenant_id")
  code         String
  name         String
  locationType LocationType @map("location_type")
  parentId     String?      @map("parent_id")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  parent        Location?      @relation("LocationTree", fields: [parentId], references: [id])
  children      Location[]     @relation("LocationTree")
  movesFromHere StockMove[]    @relation("StockMoveSource")
  movesToHere   StockMove[]    @relation("StockMoveDest")
  serialsHere   SerialNumber[]

  @@unique([tenantId, code])
  @@index([tenantId, locationType])
  @@map("locations")
  @@schema("inventory")
}

enum LocationType {
  INTERNAL
  CUSTOMER
  SUPPLIER
  TRANSIT
  INVENTORY_LOSS
  PRODUCTION
  RMA

  @@schema("inventory")
}

model StockMove {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  productId        String    @map("product_id")
  quantity         Decimal   @db.Decimal(18, 4)
  uom              String    @default("UN")
  sourceLocationId String    @map("source_location_id")
  destLocationId   String    @map("dest_location_id")
  state            MoveState @default(DRAFT)
  originDocType    String    @map("origin_doc_type")
  originDocId      String    @map("origin_doc_id")
  originLineId     String?   @map("origin_line_id")
  unitCost         Decimal?  @map("unit_cost") @db.Decimal(18, 4)
  unitCostUsd      Decimal?  @map("unit_cost_usd") @db.Decimal(18, 4)
  fxRate           Decimal?  @map("fx_rate") @db.Decimal(18, 6)
  scheduledDate    DateTime  @map("scheduled_date")
  doneDate         DateTime? @map("done_date")
  createdById      String    @map("created_by_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  cancelledAt      DateTime? @map("cancelled_at")
  cancelReason     String?   @map("cancel_reason")

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  product        Product           @relation(fields: [productId], references: [id])
  sourceLocation Location          @relation("StockMoveSource", fields: [sourceLocationId], references: [id])
  destLocation   Location          @relation("StockMoveDest", fields: [destLocationId], references: [id])
  createdBy      User              @relation("StockMoveCreatedBy", fields: [createdById], references: [id])
  serialMoves    StockMoveSerial[]

  @@index([tenantId, productId, state])
  @@index([tenantId, originDocType, originDocId])
  @@index([tenantId, destLocationId, state])
  @@index([tenantId, sourceLocationId, state])
  @@map("stock_moves")
  @@schema("inventory")
}

enum MoveState {
  DRAFT
  CONFIRMED
  ASSIGNED
  DONE
  CANCELLED

  @@schema("inventory")
}

model SerialNumber {
  id                String       @id @default(cuid())
  tenantId          String       @map("tenant_id")
  productId         String       @map("product_id")
  serial            String
  currentLocationId String?      @map("current_location_id")
  status            SerialStatus @default(IN_STOCK)
  warrantyStart     DateTime?    @map("warranty_start")
  warrantyEnd       DateTime?    @map("warranty_end")
  purchaseMoveId    String?      @map("purchase_move_id")
  metadata          Json?
  notes             String?
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  product         Product           @relation(fields: [productId], references: [id])
  currentLocation Location?         @relation(fields: [currentLocationId], references: [id])
  moveLinks       StockMoveSerial[]

  @@unique([tenantId, productId, serial])
  @@index([tenantId, status])
  @@map("serial_numbers")
  @@schema("inventory")
}

enum SerialStatus {
  IN_STOCK
  RESERVED
  DELIVERED
  RMA
  SCRAPPED

  @@schema("inventory")
}

model StockMoveSerial {
  id       String @id @default(cuid())
  moveId   String @map("move_id")
  serialId String @map("serial_id")

  move   StockMove    @relation(fields: [moveId], references: [id], onDelete: Cascade)
  serial SerialNumber @relation(fields: [serialId], references: [id])

  @@unique([moveId, serialId])
  @@map("stock_move_serials")
  @@schema("inventory")
}

// =============================================================================
// SCHEMA: sales
// =============================================================================

model SalesOrder {
  id                String          @id @default(cuid())
  tenantId          String          @map("tenant_id")
  orderNumber       Int             @map("order_number")
  customerId        String          @map("customer_id")
  state             SalesOrderState @default(DRAFT)
  currency          String          @default("ARS")
  fxRateAtConfirm   Decimal?        @map("fx_rate_at_confirm") @db.Decimal(18, 6)
  paymentTermDays   Int             @default(0) @map("payment_term_days")
  deliveryAddress   String?         @map("delivery_address")
  notes             String?
  requiresBackorder Boolean         @default(false) @map("requires_backorder")
  subtotalArs       Decimal         @default(0) @map("subtotal_ars") @db.Decimal(18, 2)
  taxAmountArs      Decimal         @default(0) @map("tax_amount_ars") @db.Decimal(18, 2)
  totalArs          Decimal         @default(0) @map("total_ars") @db.Decimal(18, 2)
  version           Int             @default(1)
  createdById       String          @map("created_by_id")
  confirmedAt       DateTime?       @map("confirmed_at")
  deliveredAt       DateTime?       @map("delivered_at")
  invoicedAt        DateTime?       @map("invoiced_at")
  cancelledAt       DateTime?       @map("cancelled_at")
  cancelReason      String?         @map("cancel_reason")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  customer  Entity           @relation(fields: [customerId], references: [id])
  createdBy User             @relation("SalesOrderCreatedBy", fields: [createdById], references: [id])
  lines     SalesOrderLine[]
  invoices  Invoice[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId, state])
  @@index([tenantId, customerId])
  @@map("sales_orders")
  @@schema("sales")
}

enum SalesOrderState {
  DRAFT
  CONFIRMED
  PARTIAL
  DELIVERED
  INVOICED
  CANCELLED

  @@schema("sales")
}

model SalesOrderLine {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  orderId           String   @map("order_id")
  productId         String   @map("product_id")
  lineNumber        Int      @map("line_number")
  description       String?
  quantity          Decimal  @db.Decimal(18, 4)
  uom               String   @default("UN")
  unitPriceArs      Decimal  @map("unit_price_ars") @db.Decimal(18, 2)
  discountPct       Decimal  @default(0) @map("discount_pct") @db.Decimal(5, 2)
  ivaRate           Decimal  @map("iva_rate") @db.Decimal(5, 2)
  quantityDelivered Decimal  @default(0) @map("quantity_delivered") @db.Decimal(18, 4)
  quantityInvoiced  Decimal  @default(0) @map("quantity_invoiced") @db.Decimal(18, 4)
  requiresBackorder Boolean  @default(false) @map("requires_backorder")
  reserveMoveId     String?  @map("reserve_move_id")
  subtotalArs       Decimal  @default(0) @map("subtotal_ars") @db.Decimal(18, 2)
  taxAmountArs      Decimal  @default(0) @map("tax_amount_ars") @db.Decimal(18, 2)
  totalArs          Decimal  @default(0) @map("total_ars") @db.Decimal(18, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id])

  @@unique([orderId, lineNumber])
  @@index([tenantId, orderId])
  @@map("sales_order_lines")
  @@schema("sales")
}

// =============================================================================
// SCHEMA: purchases
// =============================================================================

model PurchaseOrder {
  id              String             @id @default(cuid())
  tenantId        String             @map("tenant_id")
  orderNumber     Int                @map("order_number")
  supplierId      String             @map("supplier_id")
  state           PurchaseOrderState @default(DRAFT)
  currency        String             @default("USD")
  fxRateAtConfirm Decimal?           @map("fx_rate_at_confirm") @db.Decimal(18, 6)
  expectedDate    DateTime?          @map("expected_date") @db.Date
  deliveryAddress String?            @map("delivery_address")
  notes           String?
  subtotalUsd     Decimal            @default(0) @map("subtotal_usd") @db.Decimal(18, 2)
  totalUsd        Decimal            @default(0) @map("total_usd") @db.Decimal(18, 2)
  version         Int                @default(1)
  createdById     String             @map("created_by_id")
  confirmedAt     DateTime?          @map("confirmed_at")
  receivedAt      DateTime?          @map("received_at")
  cancelledAt     DateTime?          @map("cancelled_at")
  cancelReason    String?            @map("cancel_reason")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  supplier  Entity              @relation("SupplierOrders", fields: [supplierId], references: [id])
  createdBy User                @relation("POCreatedBy", fields: [createdById], references: [id])
  lines     PurchaseOrderLine[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId, state])
  @@map("purchase_orders")
  @@schema("purchases")
}

enum PurchaseOrderState {
  DRAFT
  CONFIRMED
  PARTIAL
  RECEIVED
  CANCELLED

  @@schema("purchases")
}

model PurchaseOrderLine {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  orderId          String   @map("order_id")
  productId        String   @map("product_id")
  lineNumber       Int      @map("line_number")
  description      String?
  quantity         Decimal  @db.Decimal(18, 4)
  uom              String   @default("UN")
  unitCostUsd      Decimal  @map("unit_cost_usd") @db.Decimal(18, 4)
  quantityReceived Decimal  @default(0) @map("quantity_received") @db.Decimal(18, 4)
  incomingMoveId   String?  @map("incoming_move_id")
  subtotalUsd      Decimal  @default(0) @map("subtotal_usd") @db.Decimal(18, 2)
  totalUsd         Decimal  @default(0) @map("total_usd") @db.Decimal(18, 2)
  salesOrderId     String?  @map("sales_order_id")
  salesOrderLineId String?  @map("sales_order_line_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id])

  @@unique([orderId, lineNumber])
  @@map("purchase_order_lines")
  @@schema("purchases")
}

// =============================================================================
// SCHEMA: fiscal
// =============================================================================

model PosNumber {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  number      Int
  description String?
  isFceMipyme Boolean  @default(false) @map("is_fce_mipyme")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  invoices Invoice[]

  @@unique([tenantId, number])
  @@map("pos_numbers")
  @@schema("fiscal")
}

model Invoice {
  id            String       @id @default(cuid())
  tenantId      String       @map("tenant_id")
  salesOrderId  String?      @map("sales_order_id")
  posNumberId   String       @map("pos_number_id")
  invoiceType   Int          @map("invoice_type")
  invoiceNumber Int?         @map("invoice_number")
  docType       Int          @default(80) @map("doc_type")
  docNumber     String       @map("doc_number")
  concept       Int          @default(1)
  issueDate     DateTime     @map("issue_date") @db.Date
  currency      String       @default("PES")
  fxRate        Decimal      @default(1) @map("fx_rate") @db.Decimal(18, 6)
  netAmount     Decimal      @map("net_amount") @db.Decimal(18, 2)
  ivaAmount     Decimal      @map("iva_amount") @db.Decimal(18, 2)
  totalAmount   Decimal      @map("total_amount") @db.Decimal(18, 2)
  state         InvoiceState @default(PENDING)
  cae           String?
  caeExpiry     DateTime?    @map("cae_expiry") @db.Date
  caea          String?
  errorCode     String?      @map("error_code")
  errorMsg      String?      @map("error_msg") @db.Text
  retryCount    Int          @default(0) @map("retry_count")
  requestXml    String?      @map("request_xml") @db.Text
  responseXml   String?      @map("response_xml") @db.Text
  isContingency Boolean      @default(false) @map("is_contingency")
  version       Int          @default(1)
  createdById   String       @map("created_by_id")
  approvedAt    DateTime?    @map("approved_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  salesOrder   SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  posNumberRel PosNumber     @relation(fields: [posNumberId], references: [id])
  createdBy    User          @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  lines        InvoiceLine[]
  arcaLogs     ArcaLog[]

  @@index([tenantId, state])
  @@index([tenantId, cae])
  @@map("invoices")
  @@schema("fiscal")
}

enum InvoiceState {
  PENDING
  QUEUED
  PROCESSING
  APPROVED
  FAILED
  VOIDED

  @@schema("fiscal")
}

model InvoiceLine {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  invoiceId        String   @map("invoice_id")
  lineNumber       Int      @map("line_number")
  description      String
  quantity         Decimal  @db.Decimal(18, 4)
  unitPrice        Decimal  @map("unit_price") @db.Decimal(18, 2)
  bonus            Decimal  @default(0) @db.Decimal(18, 2)
  ivaId            Int      @map("iva_id")
  ivaAmount        Decimal  @map("iva_amount") @db.Decimal(18, 2)
  totalAmount      Decimal  @map("total_amount") @db.Decimal(18, 2)
  salesOrderLineId String?  @map("sales_order_line_id")
  createdAt        DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, lineNumber])
  @@map("invoice_lines")
  @@schema("fiscal")
}

model ArcaLog {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  invoiceId   String   @map("invoice_id")
  attempt     Int
  method      String
  requestXml  String   @map("request_xml") @db.Text
  responseXml String?  @map("response_xml") @db.Text
  resultCode  String?  @map("result_code")
  errorCode   String?  @map("error_code")
  errorMsg    String?  @map("error_msg")
  durationMs  Int?     @map("duration_ms")
  createdAt   DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, invoiceId])
  @@map("arca_logs")
  @@schema("fiscal")
}

// =============================================================================
// SCHEMA: accounting
// =============================================================================

model BankAccount {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  bankName  String   @map("bank_name")
  cbu       String?
  alias     String?
  currency  String   @default("ARS")
  balance   Decimal  @default(0) @db.Decimal(18, 2)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  transactions BankTx[]

  @@map("bank_accounts")
  @@schema("accounting")
}

model Receipt {
  id            String       @id @default(cuid())
  tenantId      String       @map("tenant_id")
  receiptType   ReceiptType  @map("receipt_type")
  entityId      String       @map("entity_id")
  description   String?
  amountArs     Decimal      @map("amount_ars") @db.Decimal(18, 2)
  currency      String       @default("ARS")
  fxRate        Decimal      @default(1) @map("fx_rate") @db.Decimal(18, 6)
  paymentMethod String       @map("payment_method")
  bankAccountId String?      @map("bank_account_id")
  state         ReceiptState @default(DRAFT)
  version       Int          @default(1)
  createdById   String       @map("created_by_id")
  confirmedAt   DateTime?    @map("confirmed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  entity    Entity  @relation(fields: [entityId], references: [id])
  createdBy User    @relation("ReceiptCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId, entityId])
  @@map("receipts")
  @@schema("accounting")
}

enum ReceiptType {
  COBRO
  PAGO

  @@schema("accounting")
}

enum ReceiptState {
  DRAFT
  CONFIRMED
  CANCELLED

  @@schema("accounting")
}

model BankTx {
  id            String     @id @default(cuid())
  tenantId      String     @map("tenant_id")
  bankAccountId String     @map("bank_account_id")
  date          DateTime   @db.Date
  description   String
  amount        Decimal    @db.Decimal(18, 2)
  txType        BankTxType @map("tx_type")
  reference     String?
  reconciled    Boolean    @default(false)
  createdAt     DateTime   @default(now()) @map("created_at")

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([tenantId, bankAccountId])
  @@map("bank_transactions")
  @@schema("accounting")
}

enum BankTxType {
  CREDIT
  DEBIT

  @@schema("accounting")
}
