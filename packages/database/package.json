{
  "name": "@erp/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:create": "prisma migrate dev --create-only",
    "reset": "prisma migrate reset --force",
    "seed": "tsx --tsconfig tsconfig.json prisma/seed.ts",
    "studio": "prisma studio",
    "format": "prisma format",
    "setup:sql": "node -e \"const {execSync}=require('child_process'),fs=require('fs'),path=require('path');const sql=fs.readFileSync(path.join(__dirname,'prisma/migrations/post/001_stock_views_and_functions.sql'),'utf8');execSync('docker exec -i oppen_postgres psql -U erp -d erp_dev',{input:sql,stdio:['pipe','inherit','inherit']})\""
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "rimraf": "^6.0.1"
  },
  "prisma": {
    "seed": "tsx --tsconfig tsconfig.json prisma/seed.ts"
  }
}
