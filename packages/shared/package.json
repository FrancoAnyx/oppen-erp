{
    "name":  "@erp/shared",
    "version":  "0.1.0",
    "private":  true,
    "main":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "default":  "./dist/index.js"
                          },
                    "./errors":  {
                                     "types":  "./dist/errors/index.d.ts",
                                     "default":  "./dist/errors/index.js"
                                 },
                    "./value-objects":  {
                                            "types":  "./dist/value-objects/index.d.ts",
                                            "default":  "./dist/value-objects/index.js"
                                        }
                },
    "scripts":  {
                    "build":  "tsc -p tsconfig.json",
                    "dev":  "tsc -p tsconfig.json --watch",
                    "clean":  "rimraf dist",
                    "lint":  "eslint src --max-warnings 0",
                    "test":  "vitest run",
                    "test:watch":  "vitest"
                },
    "dependencies":  {
                         "decimal.js":  "^10.6.0"
                     },
    "devDependencies":  {
                            "@types/node":  "^22.7.0",
                            "rimraf":  "^6.0.1",
                            "typescript":  "^5.6.3",
                            "vitest":  "^2.1.2"
                        }
}
