# ============================================================
# .env.example — Copiar como .env y completar
# ============================================================

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database — debe coincidir con docker-compose.yml
DATABASE_URL=postgresql://erp:erp_dev_password@localhost:5432/erp_dev

# Auth
JWT_SECRET=dev-secret-change-me-in-production-minimum-32-chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Redis (BullMQ para facturación ARCA asíncrona)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=erp_dev_redis

# CORS
CORS_ORIGINS=http://localhost:3001

# ARCA / AFIP (dejar vacíos en desarrollo, activa mock automático)
ARCA_ENV=homologation
ARCA_CUIT_EMISOR=
ARCA_PUNTO_VENTA=1
ARCA_CERT=
ARCA_PRIVATE_KEY=

# Seed datos iniciales (solo para desarrollo)
SEED_TENANT_NAME=DEMO EMPRESA S.R.L.
SEED_TENANT_CUIT=20-12345678-9
SEED_TENANT_IVA_CONDITION=RI
SEED_TENANT_POS_NUMBER=1
SEED_ADMIN_EMAIL=admin@demo.local
SEED_ADMIN_PASSWORD=Admin1234!
